{
  "name": "smart-traffic-backend",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "services/*",
    "gateway"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:auth\" \"npm run dev:vehicle\" \"npm run dev:traffic\" \"npm run dev:incident\" \"npm run dev:notification\" \"npm run dev:gateway\"",
    "dev:auth": "cd services/auth-service && npm run dev",
    "dev:vehicle": "cd services/vehicle-service && npm run dev",
    "dev:traffic": "cd services/traffic-service && npm run dev",
    "dev:incident": "cd services/incident-service && npm run dev",
    "dev:notification": "cd services/notification-service && npm run dev",
    "dev:gateway": "cd gateway && npm run dev",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "test": "npm run test --workspace auth-service"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "jest": "^29.7.0"
  }
}
