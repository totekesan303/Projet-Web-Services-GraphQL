# ==========================================
# SMART TRAFFIC PLATFORM - ENV EXAMPLE
# ==========================================

# Copy this file to .env and fill in your values

# JWT Configuration
JWT_SECRET=your_super_secret_key_here
JWT_EXPIRES_IN=24h

# Database Configuration
DB_ROOT_PASSWORD=rootpass

# Service URLs (for Docker internal communication)
AUTH_SERVICE_URL=http://auth-service:4001
VEHICLE_SERVICE_URL=http://vehicle-service:4002
TRAFFIC_SERVICE_URL=http://traffic-service:4003
INCIDENT_SERVICE_URL=http://incident-service:4004
NOTIFICATION_SERVICE_URL=http://notification-service:4005

# Redis
REDIS_URL=redis://redis:6379

# Frontend
VITE_API_URL=http://localhost:4000/graphql
VITE_WS_URL=ws://localhost:4005/graphql
